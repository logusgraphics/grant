# =============================================================================
# Grant Platform – E2E / test environment
# =============================================================================
# Copy to .env.test. Used with:
#   docker compose -f docker-compose.e2e.yml --env-file .env.test up -d
#
# Compose interpolation (${VAR}) reads from --env-file .env.test.
# The API container also receives these via env_file: .env.test at runtime.
# The host test runner (Vitest) reads E2E_* from this file via setup.ts.
# =============================================================================

# Postgres – for Compose and API container
POSTGRES_DB=grant_e2e
POSTGRES_USER=grant_user
POSTGRES_PASSWORD=grant_password

# Redis – for Compose and API container
REDIS_PASSWORD=grant_redis_password

# Host-side: migrate/seed and test runner use E2E stack (ports 5433, 6380, 4001)
# Port 4001 avoids conflict with demo API on 4000. DB_URL used when NODE_ENV=test (e2e.sh).
DB_URL=postgresql://grant_user:grant_password@localhost:5433/grant_e2e
E2E_API_BASE_URL=http://localhost:4001
E2E_DB_URL=postgresql://grant_user:grant_password@localhost:5433/grant_e2e
E2E_REDIS_HOST=localhost
E2E_REDIS_PORT=6380
E2E_REDIS_PASSWORD=grant_redis_password

# MFA — required for /api/auth/mfa/setup and related flows (E2E API; test-only key)
# docker-compose.e2e.yml also sets these on the api service; keep values aligned if you override.
AUTH_MFA_SECRET_ENCRYPTION_KEY=e2e-grant-mfa-secret-key-min-32-chars-long
AUTH_MFA_TOTP_ISSUER=Grant-E2E
