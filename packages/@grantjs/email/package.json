{
  "name": "@grantjs/email",
  "version": "1.0.0",
  "private": true,
  "description": "Email adapters for Grant (console, mailgun, mailjet, SES, SMTP)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./console": {
      "types": "./src/console/index.ts",
      "default": "./src/console/index.ts"
    },
    "./mailgun": {
      "types": "./src/mailgun/index.ts",
      "default": "./src/mailgun/index.ts"
    },
    "./mailjet": {
      "types": "./src/mailjet/index.ts",
      "default": "./src/mailjet/index.ts"
    },
    "./ses": {
      "types": "./src/ses/index.ts",
      "default": "./src/ses/index.ts"
    },
    "./smtp": {
      "types": "./src/smtp/index.ts",
      "default": "./src/smtp/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@grantjs/core": "workspace:*"
  },
  "peerDependencies": {
    "mailgun.js": "^10",
    "form-data": "^4",
    "node-mailjet": "^6",
    "@aws-sdk/client-ses": "^3",
    "nodemailer": "^6 || ^7",
    "typescript": "^6"
  },
  "peerDependenciesMeta": {
    "mailgun.js": {
      "optional": true
    },
    "form-data": {
      "optional": true
    },
    "node-mailjet": {
      "optional": true
    },
    "@aws-sdk/client-ses": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    }
  },
  "devDependencies": {
    "mailgun.js": "^12.7.1",
    "form-data": "^4.0.2",
    "node-mailjet": "^6.0.6",
    "@aws-sdk/client-ses": "^3.1030.0",
    "nodemailer": "^8.0.5",
    "@types/nodemailer": "^8.0.0",
    "@types/node": "^25.6.0",
    "typescript": "^6"
  },
  "license": "MIT"
}
