{
  "name": "@grantjs/i18n",
  "version": "1.0.0",
  "private": true,
  "description": "Shared i18n locale constants and translation data for Grant API and web",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "files": [
    "src/**/*",
    "locales/**/*"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./locales/en.json": "./locales/en.json",
    "./locales/de.json": "./locales/de.json",
    "./loader": "./src/loader.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6"
  }
}
