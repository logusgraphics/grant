{
  "name": "@grantjs/env",
  "version": "1.0.0",
  "private": true,
  "description": "Shared env loader and Zod-validated schema for Grant platform. Loads .env hierarchy from monorepo root; no dotenv-cli needed in scripts.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6"
  }
}
