{
  "name": "@grantjs/client",
  "version": "1.0.1",
  "description": "Browser SDK for Grant authorization - React hooks and components for permission-based UI rendering",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "grant",
    "authorization",
    "permissions",
    "rbac",
    "role-based-access-control",
    "react",
    "hooks",
    "access-control",
    "typescript",
    "multi-tenant",
    "sdk",
    "client",
    "browser"
  ],
  "author": {
    "name": "Ale Heredia",
    "email": "ale@grantjs.org",
    "url": "https://grantjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grant-js/grant.git",
    "directory": "packages/@grantjs/client"
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:install": "./scripts/test-install.sh",
    "prepublishOnly": "pnpm run build && pnpm test:run"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@grantjs/schema": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "typescript": "^6",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  }
}
