{
  "name": "@grantjs/logger",
  "version": "1.0.0",
  "private": true,
  "description": "Pino-based logger adapter implementing the ILogger port from @grantjs/core",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@grantjs/core": "workspace:*",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "@types/node": "^24.7.2",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT"
}
