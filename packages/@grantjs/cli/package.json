{
  "name": "@grantjs/cli",
  "version": "1.0.0",
  "description": "Grant CLI - Setup, authentication, and typings generation for @grantjs/server",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "grant": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "grant",
    "cli",
    "authorization",
    "setup",
    "typings",
    "api-key"
  ],
  "author": {
    "name": "Ale Heredia",
    "email": "ale@grantjs.org",
    "url": "https://grantjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grant-js/grant.git",
    "directory": "packages/@grantjs/cli"
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm test:run"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^13.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "typescript": "^6",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
