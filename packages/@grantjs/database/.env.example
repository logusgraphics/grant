# Database package – local dev
# Root .env is loaded automatically when you run from repo root (e.g. pnpm db:migrate, pnpm db:seed) via dotenv-cli.
# Running db scripts from this directory alone will not load root .env; use root scripts instead.

DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
