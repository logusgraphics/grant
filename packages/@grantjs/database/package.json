{
  "name": "@grantjs/database",
  "version": "1.0.0",
  "private": true,
  "description": "Database schemas, migrations, and utilities for Grant",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "files": [
    "src/**/*",
    "migrations/**/*",
    "drizzle.config.ts"
  ],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:permissions": "tsx src/scripts/seed-permissions.ts",
    "db:seed:system-user": "tsx src/scripts/seed-system-user.ts",
    "db:reset": "tsx src/scripts/reset-db.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@grantjs/constants": "workspace:*",
    "@grantjs/core": "workspace:*",
    "@grantjs/env": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-seed": "^0.3.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.20.4",
    "typescript": "^6"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
