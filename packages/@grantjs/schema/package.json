{
  "name": "@grantjs/schema",
  "version": "1.0.0",
  "description": "GraphQL schema and generated types for Grant",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "graphql-codegen --config codegen.ts generate --watch",
    "generate": "graphql-codegen --config codegen.ts generate",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,graphql}\" --ignore-path .gitignore",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/client-preset": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.0.0",
    "@parcel/watcher": "^2.5.4",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6"
  }
}
