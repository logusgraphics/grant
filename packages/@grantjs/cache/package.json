{
  "name": "@grantjs/cache",
  "version": "1.0.0",
  "description": "Cache adapters for Grant (memory, Redis)",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./memory": {
      "types": "./src/memory/index.ts",
      "default": "./src/memory/index.ts"
    },
    "./redis": {
      "types": "./src/redis/index.ts",
      "default": "./src/redis/index.ts"
    }
  },
  "files": [
    "src/**/*"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@grantjs/core": "workspace:*"
  },
  "peerDependencies": {
    "ioredis": "^5",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "ioredis": "^5.10.0",
    "@types/node": "^24.7.2",
    "typescript": "^5"
  },
  "license": "MIT"
}
