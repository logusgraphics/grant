{
  "name": "@grantjs/server",
  "version": "1.0.0",
  "description": "Server SDK for Grant authorization - Middleware and guards for Express, Fastify, NestJS, and Next.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "import": "./dist/fastify.mjs",
      "require": "./dist/fastify.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.cjs"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "import": "./dist/nest.mjs",
      "require": "./dist/nest.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "grant",
    "authorization",
    "permissions",
    "rbac",
    "role-based-access-control",
    "express",
    "fastify",
    "nestjs",
    "nextjs",
    "middleware",
    "access-control",
    "typescript",
    "multi-tenant",
    "sdk",
    "server"
  ],
  "author": {
    "name": "Alejandro Heredia",
    "email": "ale@logus.graphics",
    "url": "https://logus.graphics"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/logusgraphics/grant.git",
    "directory": "packages/@grantjs/server"
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && pnpm test:run"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@grantjs/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "express": "^5.1.0",
    "fastify": "^5.7.2",
    "next": "^16.1.7",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "express": "^4 || ^5",
    "fastify": "^4 || ^5",
    "next": ">=13.0.0 <17.0.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0"
  }
}
