{
  "name": "@logusgraphics/grant-database",
  "version": "1.0.0",
  "description": "Database schemas, migrations, and utilities for Grant platform",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/**/*",
    "migrations/**/*",
    "drizzle.config.ts"
  ],
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "tsx src/scripts/reset-db.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.4",
    "drizzle-seed": "^0.3.1",
    "postgres": "^3.4.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "eslint": "^8.57.0",
    "tsx": "^4.20.4",
    "typescript": "^5"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.44.4"
  }
}
