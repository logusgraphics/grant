{
  "name": "@logusgraphics/grant-schema",
  "version": "1.0.0",
  "description": "GraphQL schema and generated types for Grant platform",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "graphql-codegen --config codegen.ts generate",
    "generate:watch": "graphql-codegen --config codegen.ts generate --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/client-preset": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-resolvers": "^5.0.0",
    "@types/node": "^24.7.2",
    "eslint": "^8.57.0",
    "typescript": "^5"
  }
}
