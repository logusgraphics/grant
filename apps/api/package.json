{
  "name": "grant-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "db:generate": "pnpm --filter @logusgraphics/grant-database db:generate",
    "db:migrate": "pnpm --filter @logusgraphics/grant-database db:migrate",
    "db:seed": "pnpm --filter @logusgraphics/grant-database db:seed",
    "db:reset": "pnpm --filter @logusgraphics/grant-database db:reset"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@faker-js/faker": "^9.6.0",
    "@graphql-tools/load-files": "^7.0.1",
    "@logusgraphics/grant-constants": "workspace:*",
    "@logusgraphics/grant-database": "workspace:*",
    "@logusgraphics/grant-schema": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.4",
    "drizzle-seed": "^0.3.1",
    "express": "^4.18.2",
    "graphql-type-json": "^0.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.7",
    "slugify": "^1.6.6",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.19.17",
    "@types/pg": "^8.15.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "tsx": "^4.20.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
