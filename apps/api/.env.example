# =============================================================================
# Grant API – Full env reference
# =============================================================================
# The API reads env via @grantjs/env, which loads from the **repo root**:
#   .env → .env.local → .env.{NODE_ENV} → .env.{NODE_ENV}.local
# So for local dev, use the root .env (see repo root .env.example); you do not
# need to duplicate vars here. In Docker, the API service may also receive
# apps/api/.env (see docker-compose.yml env_file). This file is the **full
# reference** of every env var the API supports; copy to apps/api/.env only if
# you need API-specific overrides (e.g. when running the API in Docker with
# both root .env and apps/api/.env).
# =============================================================================

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------

# Log level: trace | debug | info | warn | error | fatal (default: info in production, debug otherwise)
# Applied at logger bootstrap; affects all modules using the shared logger.
LOG_LEVEL=debug

# Pretty-print logs for readability (default: true in development, false otherwise)
LOG_PRETTY_PRINT=true

# ----------------------------------------------------------------------------
# Metrics (Prometheus)
# ----------------------------------------------------------------------------
# Config contract for a future /metrics endpoint. Implementation: see docs/advanced-topics/metrics.md.

# Enable Prometheus metrics collection (default: false)
METRICS_ENABLED=false

# Metrics HTTP path (default: /metrics)
METRICS_ENDPOINT=/metrics

# Collect default metrics e.g. CPU, memory (default: true)
METRICS_COLLECT_DEFAULTS=true

# ----------------------------------------------------------------------------
# Telemetry (log shipping)
# ----------------------------------------------------------------------------
# Adapter for sending request/summary logs to a backend (e.g. CloudWatch Logs).

# Provider: none | cloudwatch (default: none)
TELEMETRY_PROVIDER=none

# CloudWatch (when TELEMETRY_PROVIDER=cloudwatch)
TELEMETRY_CLOUDWATCH_REGION=us-east-1
TELEMETRY_CLOUDWATCH_LOG_GROUP=
TELEMETRY_CLOUDWATCH_LOG_STREAM_PREFIX=grant-api

# ----------------------------------------------------------------------------
# Analytics (optional; port + adapters, e.g. Umami)
# ----------------------------------------------------------------------------

# Enable and provider: none | umami (default: none)
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=none

# Umami (when ANALYTICS_PROVIDER=umami)
ANALYTICS_UMAMI_API_URL=
ANALYTICS_UMAMI_WEBSITE_ID=
ANALYTICS_UMAMI_HOSTNAME=grant-api

# ----------------------------------------------------------------------------
# Tracing (OpenTelemetry)
# ----------------------------------------------------------------------------

TRACING_ENABLED=false
TRACING_BACKEND=jaeger
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACING_SAMPLING_RATE=1.0
TRACING_SERVICE_NAME=grant-api

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# DB_URL: when unset, built from root POSTGRES_* (see repo root .env). Set here only to override.

# Database connection pool settings
DB_POOL_MAX=20
DB_POOL_MIN=2
# Connection timeout in seconds (default: 30)
DB_CONNECTION_TIMEOUT=30
# Idle timeout in seconds (default: 20)
DB_IDLE_TIMEOUT=20
# Query timeout in milliseconds (default: 60000)
DB_QUERY_TIMEOUT=60000

# Enable database query logging (default: true in development, false in production)
DB_LOG_QUERIES=true

# ----------------------------------------------------------------------------
# JWT Configuration
# ----------------------------------------------------------------------------

# Access token expiration in minutes (default: 15)
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15

# Refresh token expiration in days (default: 30)
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# Cache-Control max-age in seconds for /.well-known/jwks.json (default: 300).
JWT_JWKS_MAX_AGE_SECONDS=300

# TTL in seconds for the cached system signing key (default: 300). Invalidated on rotation.
JWT_SYSTEM_SIGNING_KEY_CACHE_TTL_SECONDS=300

# ----------------------------------------------------------------------------
# Authentication Settings
# ----------------------------------------------------------------------------

# Provider verification expiration in days (default: 7). User can resend link during this window; after this, login is blocked. Synced to apps/web/.env by config app.
AUTH_PROVIDER_VERIFICATION_EXPIRATION_DAYS=7

# OTP verification token validity in minutes (default: 5). Backend enforces this; email shows "expires in X minutes". Synced to apps/web/.env by config app.
AUTH_OTP_VALIDITY_MINUTES=5

# Maximum failed login attempts before lockout (default: 5)
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5

# Account lockout duration in minutes after max failed attempts (default: 15)
AUTH_LOCKOUT_DURATION_MINUTES=15

# Password reset OTP validity in minutes (default: 60)
AUTH_PASSWORD_RESET_OTP_VALIDITY_MINUTES=60

# ----------------------------------------------------------------------------
# MFA / TOTP Settings
# ----------------------------------------------------------------------------

# Issuer label used in authenticator apps via otpauth URI (default: Grant)
AUTH_MFA_TOTP_ISSUER=Grant

# TOTP period in seconds (RFC 6238 default: 30)
AUTH_MFA_TOTP_PERIOD_SECONDS=30

# Allowed TOTP drift window in time-steps (default: 1 => +/- 1 step)
AUTH_MFA_TOTP_WINDOW=1

# Maximum MFA verification attempts per rate-limit window (default: 5)
AUTH_MFA_VERIFY_MAX_ATTEMPTS=5

# MFA verification rate-limit window in minutes (default: 15)
AUTH_MFA_VERIFY_WINDOW_MINUTES=15

# Optional MFA session TTL in minutes (default: 1440 = 24h)
AUTH_MFA_SESSION_TTL_MINUTES=1440

# Symmetric encryption key for MFA secrets at rest (scrypt-derived AES-256-GCM)
# [REQUIRED in production when MFA is enabled]
AUTH_MFA_SECRET_ENCRYPTION_KEY=

# Minimum AAL after login when user has MFA enrolled: aal1 (default) or aal2
AUTH_MIN_AAL_AT_LOGIN=aal1

# When > 0 and min AAL is aal2: stale MFA (JWT mfa_auth_time) is treated as AAL1 for policy (0 = off)
AUTH_MFA_STEP_UP_MAX_AGE_SECONDS=0

# ----------------------------------------------------------------------------
# Token Configuration (secure tokens, OTP, bcrypt)
# ----------------------------------------------------------------------------

# Default validity in minutes for secure tokens e.g. OTP, verification (default: 60)
TOKEN_DEFAULT_VALIDITY_MINUTES=60

# Default token length in bytes; hex output is 2x (default: 32)
TOKEN_DEFAULT_LENGTH=32

# bcrypt hashing rounds for secrets (default: 10)
TOKEN_BCRYPT_ROUNDS=10

# ----------------------------------------------------------------------------
# Cache Configuration
# ----------------------------------------------------------------------------

# Cache strategy: memory | redis
# - memory: In-memory cache (single instance only or local development)
# - redis: Redis cache (for distributed/multi-instance deployments or production)
CACHE_STRATEGY=memory

# Default cache TTL (Time To Live) in seconds (default: 3600 = 1 hour)
CACHE_DEFAULT_TTL=3600

# Maximum cache size in bytes for in-memory cache (default: 104857600 = 100MB)
CACHE_MAX_SIZE=104857600

# ----------------------------------------------------------------------------
# Redis Configuration (only needed if CACHE_STRATEGY=redis)
# ----------------------------------------------------------------------------

# Redis server hostname
REDIS_HOST=localhost

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis authentication password (recommended in production)
REDIS_PASSWORD=grant_redis_password

# Redis database number (default: 0)
REDIS_DB=0

# Redis key prefix for namespacing (default: grant:)
REDIS_KEY_PREFIX=grant:

# Redis connection timeout in milliseconds (default: 10000)
REDIS_CONNECTION_TIMEOUT=10000

# Enable TLS for Redis connection (default: false, set true for production)
REDIS_ENABLE_TLS=false

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------

# Frontend URL for CORS
# [REQUIRED in production]
SECURITY_FRONTEND_URL=${APP_URL}

# Additional allowed origins for CORS (comma-separated)
# Example: https://app.example.com,https://admin.example.com
SECURITY_ADDITIONAL_ORIGINS=

# Enable Helmet security headers (default: true)
SECURITY_ENABLE_HELMET=true

# Enable rate limiting (default: true in production, false in development)
SECURITY_ENABLE_RATE_LIMIT=false

# Rate limit: maximum requests per window (default: 100)
SECURITY_RATE_LIMIT_MAX=100

# Rate limit: time window in minutes (default: 15)
SECURITY_RATE_LIMIT_WINDOW_MINUTES=15

# Rate limit for auth endpoints (login, refresh, cli-callback, token): max requests per window (default: 20)
SECURITY_RATE_LIMIT_AUTH_MAX=20

# Rate limit for auth endpoints: time window in minutes (default: 15)
SECURITY_RATE_LIMIT_AUTH_WINDOW_MINUTES=15

# Per-tenant rate limiting (noisy neighbor protection). When enabled, authenticated requests with scope are also limited by tenant (default: false)
SECURITY_RATE_LIMIT_PER_TENANT_ENABLED=false

# Per-tenant rate limit: maximum requests per window per tenant (default: 200)
SECURITY_RATE_LIMIT_PER_TENANT_MAX=200

# Per-tenant rate limit: time window in minutes (default: 15)
SECURITY_RATE_LIMIT_PER_TENANT_WINDOW_MINUTES=15

# API Key for external service authentication (optional)
SECURITY_API_KEY=

# Enable database Row-Level Security enforcement for scoped requests
SECURITY_ENABLE_RLS=true

# RLS restricted role name; must match the role created in DB migration (default: grant_app_restricted)
SECURITY_RLS_ROLE=grant_app_restricted

# Development-only CORS origins (comma-separated). In production only SECURITY_FRONTEND_URL and SECURITY_ADDITIONAL_ORIGINS apply.
# Default: http://localhost:3000,http://localhost:3001,https://studio.apollographql.com,https://apollo-studio-embed.vercel.app
CORS_DEV_ORIGINS=http://localhost:3000,http://localhost:3004,http://localhost:5173,https://studio.apollographql.com,https://apollo-studio-embed.vercel.app

# ----------------------------------------------------------------------------
# Apollo/GraphQL Configuration
# ----------------------------------------------------------------------------

# Enable GraphQL introspection (default: true in development, false in production)
APOLLO_INTROSPECTION=true

# Enable GraphQL playground (default: true in development, false in production)
APOLLO_PLAYGROUND=true

# Include stack traces in GraphQL errors (default: true in development, false in production)
APOLLO_INCLUDE_STACKTRACE=true

# ----------------------------------------------------------------------------
# Swagger/OpenAPI Configuration
# ----------------------------------------------------------------------------

# Enable Swagger UI at /api-docs (default: true)
SWAGGER_ENABLED=true

# Swagger UI site title (default: Grant API Docs)
SWAGGER_SITE_TITLE=Grant API Docs

# Persist authorization between page refreshes (default: true)
SWAGGER_PERSIST_AUTHORIZATION=true

# Display request duration in responses (default: true)
SWAGGER_DISPLAY_REQUEST_DURATION=true

# Enable filter/search in operations (default: true)
SWAGGER_FILTER=true

# Enable "Try it out" by default (default: true)
SWAGGER_TRY_IT_OUT_ENABLED=true

# Depth to expand models/schemas (default: 3)
SWAGGER_MODELS_EXPAND_DEPTH=3

# Depth to expand individual model properties (default: 3)
SWAGGER_MODEL_EXPAND_DEPTH=3

# Documentation expansion: list | full | none (default: list)
SWAGGER_DOC_EXPANSION=list

# Enable deep linking for sharing (default: true)
SWAGGER_DEEP_LINKING=true

# Display operation IDs (default: false)
SWAGGER_DISPLAY_OPERATION_ID=false

# Syntax highlighting theme: agate | arta | monokai | nord | obsidian | tomorrow-night (default: monokai)
SWAGGER_SYNTAX_THEME=monokai

# Show extensions (default: true)
SWAGGER_SHOW_EXTENSIONS=true

# Show common extensions (default: true)
SWAGGER_SHOW_COMMON_EXTENSIONS=true

# Production server URL shown in OpenAPI document in dev mode (default: https://api.grantjs.org)
OPENAPI_PRODUCTION_URL=

# ----------------------------------------------------------------------------
# Internationalization (i18n)
# ----------------------------------------------------------------------------

# Default locale; must be one of supported locales (default: en)
I18N_DEFAULT_LOCALE=en

# Enable i18n debug mode (default: true in development)
I18N_DEBUG=false

# ----------------------------------------------------------------------------
# Email Configuration
# ----------------------------------------------------------------------------

# Email provider: console | mailgun | mailjet | ses | smtp
# - console: Logs emails to console (development only)
# - mailgun: Use Mailgun service
# - mailjet: Use Mailjet service
# - ses: Use AWS Simple Email Service (SES)
# - smtp: Use standard SMTP server
EMAIL_PROVIDER=console

# From email address
# [REQUIRED]
EMAIL_FROM=noreply@yourdomain.com

# From name displayed in emails (optional)
EMAIL_FROM_NAME=Grant

# ----------------------------------------------------------------------------
# Mailgun Configuration (only needed if EMAIL_PROVIDER=mailgun)
# ----------------------------------------------------------------------------

# Mailgun API key
MAILGUN_API_KEY=

# Mailgun domain
MAILGUN_DOMAIN=

# ----------------------------------------------------------------------------
# Mailjet Configuration (only needed if EMAIL_PROVIDER=mailjet)
# ----------------------------------------------------------------------------

# Mailjet API key
MAILJET_API_KEY=

# Mailjet secret key
MAILJET_SECRET_KEY=

# ----------------------------------------------------------------------------
# SMTP Configuration (only needed if EMAIL_PROVIDER=smtp)
# ----------------------------------------------------------------------------

# SMTP server hostname
SMTP_HOST=smtp.example.com

# SMTP server port (25, 465, or 587)
SMTP_PORT=587

# SMTP username
SMTP_USER=

# SMTP password
SMTP_PASSWORD=

# Use TLS/SSL for SMTP connection (default: true for port 465, false for others)
SMTP_SECURE=false

# ----------------------------------------------------------------------------
# AWS SES Configuration (only needed if EMAIL_PROVIDER=ses)
# ----------------------------------------------------------------------------

# AWS SES client ID (Access Key ID)
# [REQUIRED if EMAIL_PROVIDER=ses]
EMAIL_SES_CLIENT_ID=

# AWS SES client secret (Secret Access Key)
# [REQUIRED if EMAIL_PROVIDER=ses]
EMAIL_SES_CLIENT_SECRET=

# AWS region for SES (default: us-east-1)
# Examples: us-east-1, us-west-2, eu-west-1, ap-southeast-1
EMAIL_SES_REGION=us-east-1

# ----------------------------------------------------------------------------
# File Storage Configuration
# ----------------------------------------------------------------------------

# Storage provider: local | s3
# - local: Local filesystem storage (development/single-server)
#   Note: local storage works for bare metal, Docker volumes, or any filesystem mount
# - s3: AWS S3 or S3-compatible storage (production/multi-server)
STORAGE_PROVIDER=local

# ----------------------------------------------------------------------------
# Local Storage Configuration (only needed if STORAGE_PROVIDER=local)
# ----------------------------------------------------------------------------

# Base path for local file storage (default: ./storage)

# Maximum file size for uploads in bytes (default: 5242880 = 5MB)
STORAGE_UPLOAD_MAX_FILE_SIZE=5242880


# Can be a local directory, Docker volume mount (e.g., /app/storage), or any filesystem path
STORAGE_LOCAL_BASE_PATH=./storage

# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# S3 Storage Configuration (only needed if STORAGE_PROVIDER=s3)
# ----------------------------------------------------------------------------

# S3 bucket name
# [REQUIRED if STORAGE_PROVIDER=s3]
STORAGE_S3_BUCKET=

# AWS region (default: us-east-1)
STORAGE_S3_REGION=us-east-1

# AWS access key ID
# [REQUIRED if STORAGE_PROVIDER=s3]
STORAGE_S3_ACCESS_KEY_ID=

# AWS secret access key
# [REQUIRED if STORAGE_PROVIDER=s3]
STORAGE_S3_SECRET_ACCESS_KEY=

# Custom S3 endpoint (optional, for S3-compatible services like MinIO)
# Example: https://s3.amazonaws.com or http://localhost:9000
STORAGE_S3_ENDPOINT=

# Public URL base (optional, e.g., CloudFront distribution URL)
# Example: https://d1234567890.cloudfront.net
STORAGE_S3_PUBLIC_URL=


# ----------------------------------------------------------------------------
# Job Scheduling Configuration
# ----------------------------------------------------------------------------

# Enable job scheduling (default: true)
JOBS_ENABLED=true

# Job scheduling provider: 'node-cron' | 'bullmq'
# - node-cron: Simple, single-instance (development/single-server)
# - bullmq: Distributed, multi-instance (production/multi-server)
# Note: BullMQ requires Redis (set CACHE_STRATEGY=redis)
JOBS_PROVIDER=node-cron

# Cron pattern for data retention cleanup job
# Default: '0 2 * * *' (daily at 2:00 AM)
# Format: minute hour day month weekday
# Examples:
#   '0 2 * * *'     - Daily at 2:00 AM
#   '0 */6 * * *'  - Every 6 hours
#   '0 0 * * 0'    - Weekly on Sunday at midnight
JOBS_DATA_RETENTION_SCHEDULE="0 2 * * *"

# Enable data retention cleanup job (default: true)
JOBS_DATA_RETENTION_ENABLED=true

# System (platform) signing key rotation
# Cron schedule (default: 0 0 1 * * = monthly, first day at midnight)
JOBS_SYSTEM_SIGNING_KEY_ROTATION_SCHEDULE="0 0 1 * *"
# Enable automatic system signing key rotation (default: false)
JOBS_SYSTEM_SIGNING_KEY_ROTATION_ENABLED=false

# ----------------------------------------------------------------------------
# BullMQ Configuration (only needed if JOBS_PROVIDER=bullmq)
# ----------------------------------------------------------------------------

# Number of retry attempts for failed jobs (default: 3)
JOBS_BULLMQ_ATTEMPTS=3

# Backoff type for retries: 'exponential' | 'fixed' (default: exponential)
JOBS_BULLMQ_BACKOFF_TYPE=exponential

# Backoff delay in milliseconds before retry (default: 2000)
JOBS_BULLMQ_BACKOFF_DELAY=2000

# Completed job retention age in seconds (default: 604800 = 7 days)
JOBS_BULLMQ_REMOVE_ON_COMPLETE_AGE=604800

# Failed job retention age in seconds (default: 2592000 = 30 days)
JOBS_BULLMQ_REMOVE_ON_FAIL_AGE=2592000


# ----------------------------------------------------------------------------
# GitHub OAuth (platform sign-in and project app flow)
# ----------------------------------------------------------------------------

# Client ID
GITHUB_CLIENT_ID=

# Client Secret
GITHUB_CLIENT_SECRET=

# Callback URL for platform sign-in (default: http://localhost:4000/api/auth/github/callback)
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback

# Callback URL for project app OAuth flow; must be registered in GitHub app (default: http://localhost:4000/api/auth/project/callback)
GITHUB_PROJECT_CALLBACK_URL=http://localhost:4000/api/auth/project/callback

# GitHub OAuth authorization URL (default: https://github.com/login/oauth/authorize)
GITHUB_AUTHORIZATION_URL=https://github.com/login/oauth/authorize

# GitHub OAuth token URL (default: https://github.com/login/oauth/access_token)
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token

# GitHub API base URL (default: https://api.github.com)
GITHUB_API_URL=https://api.github.com

# OAuth state token validity in minutes (default: 10)
GITHUB_OAUTH_STATE_VALIDITY_MINUTES=10

# Default avatar URL when user has no GitHub avatar (default: https://github.com/identicons/placeholder)
GITHUB_DEFAULT_AVATAR_URL=https://github.com/identicons/placeholder

# TTL in seconds for CLI OAuth callback payloads in cache (default: 60)
OAUTH_CLI_CALLBACK_TTL_SECONDS=60

# ----------------------------------------------------------------------------
# Project OAuth (per-project OAuth apps; provider=email, github, etc.)
# ----------------------------------------------------------------------------
# When unset, defaults are derived from SECURITY_FRONTEND_URL. Set only to override.
# Include locale in path if using next-intl (e.g. https://app.example.com/en/auth/project/email).

# PROJECT_OAUTH_EMAIL_ENTRY_URL=   # default: {SECURITY_FRONTEND_URL}/auth/project/email
# PROJECT_OAUTH_CONSENT_URL=       # default: {SECURITY_FRONTEND_URL}/auth/project/consent

# ----------------------------------------------------------------------------
# Demo mode (exposed to frontends via GET /api/config)
# ----------------------------------------------------------------------------

# Enable demo mode for limited-usage deployments (default: false)
DEMO_MODE_ENABLED=false
# Cron schedule for automatic demo DB refresh (default: every 2 days at midnight)
DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *

# ----------------------------------------------------------------------------
# Privacy & Data Retention
# ----------------------------------------------------------------------------

# Data retention period in days for deleted accounts (default: 30); exposed via GET /api/config
PRIVACY_ACCOUNT_DELETION_RETENTION_DAYS=30

# Data retention period in days for backups (default: 90)
PRIVACY_BACKUP_RETENTION_DAYS=90
