{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": ".next",
    "rootDir": "../..",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/i18n/*": ["./i18n/*"],
      "@/styles/*": ["./styles/*"],
      "@/stores/*": ["./stores/*"]
    }
  },
  "include": ["next-env.d.ts", "types/**/*.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
