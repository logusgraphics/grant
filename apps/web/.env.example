# Web App Environment Variables
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOCS_URL=http://localhost:5173
NEXT_PUBLIC_REFRESH_TOKEN_EXPIRATION_DAYS=30
# Account deletion retention (days) — keep in sync with API PRIVACY_ACCOUNT_DELETION_RETENTION_DAYS; config app can replicate
NEXT_PUBLIC_ACCOUNT_DELETION_RETENTION_DAYS=30

# Demo mode flags (synced from config app via API env)
# When true, the web app shows a banner indicating that this is a demo environment and data may be reset.
NEXT_PUBLIC_DEMO_MODE_ENABLED=false

# Cron schedule for demo database refresh (informational only; displayed in UI if desired).
NEXT_PUBLIC_DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *

# Auth (synced from config app with apps/api/.env — same key in both files)
# OTP/link validity in minutes; verification window in days (see API .env.example for descriptions)
# AUTH_OTP_VALIDITY_MINUTES=5
# AUTH_PROVIDER_VERIFICATION_EXPIRATION_DAYS=7

# Development
NODE_ENV=development
