{
  "name": "grant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Alejandro Heredia",
    "email": "ale@logus.graphics",
    "url": "https://logus.graphics"
  },
  "description": "Multi-tenant RBAC platform with monorepo architecture",
  "scripts": {
    "env:setup": "node scripts/env/setup.mjs",
    "build": "turbo build",
    "build:release": "turbo run build --filter=@grantjs/client... --filter=@grantjs/server... --filter=@grantjs/cli...",
    "predev": "pnpm env:setup",
    "dev": "turbo dev",
    "dev:docs": "pnpm --filter grant-docs dev",
    "dev:web": "pnpm --filter grant-web dev",
    "dev:api": "pnpm --filter grant-api dev",
    "dev:both": "concurrently --kill-others-on-fail --success first --raw \"pnpm dev:api\" \"pnpm dev:web\"",
    "config": "pnpm --filter grant-config dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,graphql}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,graphql}\" --ignore-path .gitignore",
    "format:apps": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md,graphql}\"",
    "format:packages": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md,graphql}\"",
    "test": "turbo test",
    "test:ui": "turbo test:ui",
    "test:coverage": "turbo test:coverage",
    "test:e2e": "./scripts/e2e.sh",
    "test:e2e:up": "./scripts/e2e.sh --up",
    "test:e2e:down": "./scripts/e2e.sh --down",
    "test:e2e:run": "./scripts/e2e.sh --test",
    "test:e2e:report": "./scripts/e2e.sh --report",
    "compliance:report": "./scripts/e2e.sh --report",
    "clean": "turbo clean",
    "type-check": "turbo type-check",
    "check:palette": "pnpm --filter @grantjs/constants run check:palette",
    "generate": "pnpm --filter @grantjs/schema generate",
    "generate:watch": "pnpm --filter @grantjs/schema generate:watch",
    "db:generate": "pnpm --filter @grantjs/database db:generate",
    "db:migrate": "pnpm --filter @grantjs/database db:migrate",
    "db:seed": "pnpm --filter @grantjs/database db:seed",
    "db:seed:permissions": "pnpm --filter @grantjs/database db:seed:permissions",
    "db:seed:system-user": "pnpm --filter @grantjs/database db:seed:system-user",
    "db:reset": "pnpm --filter @grantjs/database db:reset",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "audit": "./scripts/audit-security.sh",
    "audit:quick": "./scripts/audit-quick.sh",
    "secret-scan": "gitleaks detect --config .gitleaks.toml -v",
    "secret-scan:protect": "GITLEAKS_CONFIG=.gitleaks.toml gitleaks protect -v",
    "audit:fix": "./scripts/audit-fix.sh",
    "audit:pnpm": "pnpm audit --recursive",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build:release && changeset publish",
    "postinstall": "node scripts/env/setup.mjs --quiet"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@types/node": "^24.7.2",
    "badge-maker": "^5.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "graphql": "^16.10.0",
    "lint-staged": "^16.2.4",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.46.0",
    "vitepress": "^1.6.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.3.6",
      "@isaacs/brace-expansion": "5.0.1",
      "multer": "2.1.1",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3",
      "immutable": "3.8.3",
      "axios": "1.13.5",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@9.0.1": "9.0.7",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.0.3": "10.2.3",
      "minimatch@10.1.2": "10.2.3"
    }
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "packages/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,graphql,yml,yaml}": [
      "prettier --write"
    ]
  }
}
