# =============================================================================
# Grant Platform – Demo deployment env template
# =============================================================================
# Copy to .env.demo and set values. Used by:
#   docker compose -f docker-compose.demo.yml --env-file .env.demo up -d
#
# Do not commit .env.demo (secrets). This file is the template only.
#
# When each var is used:
#   Build time   = Docker build (build.args) — baked into web/docs/example-nextjs images
#   Deploy time  = Compose interpolation when parsing docker-compose.demo.yml (image names, postgres/redis/api env in YAML)
#   Runtime      = Container environment when the service runs (api: env_file + compose environment block)
# =============================================================================

# -----------------------------------------------------------------------------
# Deploy time – Compose interpolation (required for compose YAML)
# -----------------------------------------------------------------------------
POSTGRES_DB=grant_demo
POSTGRES_USER=grant_user
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32
REDIS_PASSWORD=change-me-use-openssl-rand-base64-32

# Optional: override image tags for CD (defaults in docker-compose.demo.yml)
# GRANT_API_IMAGE=ghcr.io/your-org/grant-platform/grant-api:demo
# GRANT_WEB_IMAGE=ghcr.io/your-org/grant-platform/grant-web:demo
# GRANT_DOCS_IMAGE=ghcr.io/your-org/grant-platform/grant-docs:demo
# GRANT_EXAMPLE_NEXTJS_IMAGE=ghcr.io/your-org/grant-platform/example-nextjs:demo

# -----------------------------------------------------------------------------
# Build time – passed as build.args (baked into image bundles)
# -----------------------------------------------------------------------------
# Web (Next.js): NEXT_PUBLIC_* are embedded at build
# NEXT_PUBLIC_API_URL=https://demo.grant.center
# NEXT_PUBLIC_APP_URL=https://demo.grant.center
# NEXT_PUBLIC_GRANT_API_URL=https://demo.grant.center
# NEXT_PUBLIC_GRANT_FRONTEND_URL=https://demo.grant.center
# NEXT_PUBLIC_DOCS_URL=https://docs.grant.center

# Docs (VitePress): VITE_* are embedded at build
# VITE_API_URL=https://demo.grant.center
# VITE_APP_URL=https://demo.grant.center

# -----------------------------------------------------------------------------
# Runtime – API service (env_file + compose environment block)
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_PORT=4000
APP_URL=https://demo.grant.center
SECURITY_FRONTEND_URL=https://demo.grant.center

# DB_URL is overridden in compose from POSTGRES_*; set only if not using compose override
# DB_URL=postgresql://grant_user:xxx@postgres:5432/grant_demo
# Redis is set in compose (REDIS_HOST, REDIS_PORT, REDIS_PASSWORD)
CACHE_STRATEGY=redis
# With API replicas (e.g. 2), total DB connections = replicas × DB_POOL_MAX. Default 20; set lower if needed (e.g. DB_POOL_MAX=10 for 2 replicas).
# DB_POOL_MAX=20

# GitHub OAuth (required for sign-in with GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://demo.grant.center/api/auth/github/callback
GITHUB_PROJECT_CALLBACK_URL=https://demo.grant.center/api/auth/project/callback

# Email (SES)
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@grant.center
EMAIL_SES_CLIENT_ID=
EMAIL_SES_CLIENT_SECRET=
EMAIL_SES_REGION=us-east-1

# Demo mode
DEMO_MODE_ENABLED=true
DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *

# Optional (runtime – API container)
LOG_LEVEL=info
SWAGGER_ENABLED=true
OPENAPI_PRODUCTION_URL=https://demo.grant.center
STORAGE_PROVIDER=local
APOLLO_PLAYGROUND=true
APOLLO_INTROSPECTION=true