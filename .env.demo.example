# =============================================================================
# Grant Platform – Demo deployment (.env.demo)
# =============================================================================
# Copy to .env.demo. Used with:
#   docker compose -f docker-compose.demo.yml --env-file .env.demo up -d
#   (or ./scripts/stack-deploy.sh, which wraps docker compose)
#
# Same structure as .env.example; only values differ. Compose interpolation
# reads from --env-file .env.demo; containers get env via env_file: .env.demo.
# Frontends receive URLs at runtime from the API (no build-time injection).
# =============================================================================

# -----------------------------------------------------------------------------
# Compose (optional; project name for demo stack)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=grant-demo

# -----------------------------------------------------------------------------
# Core infrastructure
# -----------------------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_DB=grant_demo
POSTGRES_USER=grant_user
POSTGRES_PORT=5432
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32
# API container: @grantjs/env expands ${VAR} at runtime (env_file or environment block)
DB_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

CACHE_STRATEGY=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-use-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Canonical app URL (API only: issuer fallback, CORS; not sent to frontends)
# -----------------------------------------------------------------------------

APP_URL=https://demo.grant.center
SECURITY_FRONTEND_URL=${APP_URL}
SECURITY_ADDITIONAL_ORIGINS=
GITHUB_CALLBACK_URL=${APP_URL}/api/auth/github/callback
GITHUB_PROJECT_CALLBACK_URL=${APP_URL}/api/auth/project/callback
OPENAPI_PRODUCTION_URL=${APP_URL}

# -----------------------------------------------------------------------------
# Ports
# Gateway is the single published port; all services are internal.
# API_PORT is used internally by the API containers.
# -----------------------------------------------------------------------------

GATEWAY_PORT=8080
API_PORT=4000

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------

DEMO_MODE_ENABLED=true
DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *
JOBS_PROVIDER=bullmq

# ----------------------------------------------------------------------------
# System
# ----------------------------------------------------------------------------
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# OAuth and email (demo: set if you need GitHub login or real email)
# -----------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@grant.center
EMAIL_FROM_NAME=Grant Demo
EMAIL_SES_CLIENT_ID=
EMAIL_SES_CLIENT_SECRET=
EMAIL_SES_REGION=us-east-1

# -----------------------------------------------------------------------------
# API / docs / OpenAPI (demo)
# -----------------------------------------------------------------------------

LOG_LEVEL=info
SWAGGER_ENABLED=true
STORAGE_PROVIDER=local
APOLLO_PLAYGROUND=true
APOLLO_INTROSPECTION=true
