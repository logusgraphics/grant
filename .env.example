# =============================================================================
# Grant Platform – Docker deployment env template
# =============================================================================
# Copy this file to .env and set values.
# Used by: Docker Compose (port wiring), API and backend only.
# Frontend containers (web, docs, example-nextjs) must NOT receive APP_URL,
# API_URL, DOCS_URL, BACKEND_URL — they use relative paths only.
#
# Env files: .env | .env.local | .env.development | .env.test | .env.demo |
# .env.production (and *.local). Compose: run with --env-file .env.<env> so
# config stays in env files (e.g. docker compose -f docker-compose.e2e.yml
# --env-file .env.test up). Keep a minimal .env at repo root (e.g.
# COMPOSE_PROJECT_NAME=grant) for Compose/tooling; full config uses the above.
#
# Precedence (loaded from repo root by @grantjs/env, later overrides):
#   .env → .env.local → .env.{NODE_ENV} → .env.{NODE_ENV}.local
# =============================================================================

# -----------------------------------------------------------------------------
# Compose (optional; default project name)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=grant

# -----------------------------------------------------------------------------
# Core infrastructure
# -----------------------------------------------------------------------------

POSTGRES_HOST=localhost
POSTGRES_DB=grant_db
POSTGRES_USER=grant_user
POSTGRES_PORT=5432
POSTGRES_PASSWORD=grant_password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=grant_redis_password

# -----------------------------------------------------------------------------
# Canonical app URL (API only: issuer fallback, CORS; not sent to frontends)
# -----------------------------------------------------------------------------

APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Ports (Docker Compose wiring only; apps do not read these)
# -----------------------------------------------------------------------------

API_PORT=4000
WEB_PORT=3000
DOCS_PORT=5173
EXAMPLE_PORT=3004

# ----------------------------------------------------------------------------
# Security
# ----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# API runtime
# -----------------------------------------------------------------------------

NODE_ENV=production
DEMO_MODE_ENABLED=false
DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *

# ----------------------------------------------------------------------------
# System
# ----------------------------------------------------------------------------
SYSTEM_USER_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# Observability stack (optional)
# -----------------------------------------------------------------------------

PGADMIN_EMAIL=admin@grant.dev
PGADMIN_PASSWORD=grant_password
GRAFANA_ADMIN_PASSWORD=admin
COLLECTOR_OTLP_ENABLED=true
UMAMI_DB_PASSWORD=umami
UMAMI_APP_SECRET=replace-me-with-a-random-string