# ============================================================================
# Grant - Docker Compose Environment Configuration
# ============================================================================
# This file configures the infrastructure services (PostgreSQL, Redis, PgAdmin, Grafana, Jaeger, Umami)
# Copy this file to .env to customize the services
#
# Note: This is separate from apps/api/.env which configures the API application
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL Database
# ----------------------------------------------------------------------------

# Database name
POSTGRES_DB=grant_db

# Database user
POSTGRES_USER=grant_user

# Database password
POSTGRES_PASSWORD=grant_password

# ----------------------------------------------------------------------------
# PgAdmin (Database Management UI)
# ----------------------------------------------------------------------------

# PgAdmin login email
PGADMIN_EMAIL=admin@grant.dev

# PgAdmin login password
PGADMIN_PASSWORD=grant_password

# ----------------------------------------------------------------------------
# Redis Cache
# ----------------------------------------------------------------------------

# Redis authentication password
REDIS_PASSWORD=grant_redis_password

# ----------------------------------------------------------------------------
# Grafana (Observability UI)
# ----------------------------------------------------------------------------
# Access: http://localhost:3001 (default login admin / value below)

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin

# ----------------------------------------------------------------------------
# Jaeger (Distributed Tracing)
# ----------------------------------------------------------------------------
# Access: http://localhost:16686 (UI), OTLP gRPC on 14268

# Enable OTLP receiver for trace ingestion (default: true)
COLLECTOR_OTLP_ENABLED=true

# ----------------------------------------------------------------------------
# Umami (Analytics)
# ----------------------------------------------------------------------------
# Umami app: http://localhost:3002
# Uses dedicated Postgres (umami-db) and these vars for DB + app secret.

# Umami database password (used by umami-db and umami app)
UMAMI_DB_PASSWORD=umami

# Umami app secret (replace with a random string in production)
UMAMI_APP_SECRET=replace-me-with-a-random-string

# ----------------------------------------------------------------------------
# Demo Mode (Optional)
# ----------------------------------------------------------------------------
# Enable demo mode for limited-usage deployments (default: false).
DEMO_MODE_ENABLED=false

# Cron schedule for automatic demo database refresh (default: every 2 days at midnight).
# Example: 0 0 */2 * *  -> every 2 days at 00:00.
DEMO_MODE_DB_REFRESH_SCHEDULE=0 0 */2 * *

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Copy this file: cp .env.example .env
# 2. Update passwords for production
# 3. Start services: docker-compose up -d
# 4. PgAdmin: http://localhost:8080 | Grafana: http://localhost:3001 | Jaeger: http://localhost:16686 | Umami: http://localhost:3002
# 5. API configuration: See apps/api/.env.example
# ============================================================================
