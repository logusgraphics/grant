# ============================================================================
# Grant Platform - Docker Compose Environment Configuration
# ============================================================================
# This file configures the infrastructure services (PostgreSQL, Redis, PgAdmin)
# Copy this file to .env to customize the services
#
# Note: This is separate from apps/api/.env which configures the API application
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL Database
# ----------------------------------------------------------------------------

# Database name
POSTGRES_DB=grant_platform_db

# Database user
POSTGRES_USER=grant_user

# Database password
POSTGRES_PASSWORD=grant_password

# ----------------------------------------------------------------------------
# PgAdmin (Database Management UI)
# ----------------------------------------------------------------------------

# PgAdmin login email
PGADMIN_EMAIL=admin@grant.dev

# PgAdmin login password
PGADMIN_PASSWORD=grant_password

# ----------------------------------------------------------------------------
# Redis Cache
# ----------------------------------------------------------------------------

# Redis authentication password
REDIS_PASSWORD=grant_redis_password

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# 1. Copy this file: cp .env.example .env
# 2. Update passwords for production
# 3. Start services: docker-compose up -d
# 4. Access PgAdmin: http://localhost:8080
# 5. API configuration: See apps/api/.env.example
# ============================================================================
