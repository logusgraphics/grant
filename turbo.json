{
  "globalPassThroughEnv": [
    "NODE_ENV",
    "APP_URL",
    "DOCS_URL",
    "API_PORT",
    "SYSTEM_USER_ID",
    "DB_URL",
    "POSTGRES_*",
    "DB_*",
    "CACHE_*",
    "REDIS_*",
    "JWT_*",
    "AUTH_*",
    "TOKEN_*",
    "GITHUB_*",
    "OAUTH_*",
    "PROJECT_OAUTH_*",
    "SECURITY_*",
    "CORS_*",
    "LOG_*",
    "APOLLO_*",
    "SWAGGER_*",
    "OPENAPI_*",
    "I18N_*",
    "EMAIL_*",
    "MAILGUN_*",
    "MAILJET_*",
    "SMTP_*",
    "METRICS_*",
    "TELEMETRY_*",
    "ANALYTICS_*",
    "TRACING_*",
    "JAEGER_*",
    "OTLP_*",
    "OTEL_*",
    "STORAGE_*",
    "PRIVACY_*",
    "JOBS_*",
    "DEMO_*",
    "E2E_*",
    "BENCHMARK_*",
    "APP_VERSION",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "db:generate": {
      "cache": false,
      "outputs": ["src/migrations/**"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:ui": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": ["**/.env.*local", "**/.env"]
}
